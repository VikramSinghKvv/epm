{
  "name": "epm-complete",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9.9.1",
    "@sap/hdi-deploy": "^4",
    "@sap/xssec": "^4",
    "hdb": "^0.19"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-po-management": "cds watch --open app.pomanagement/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project1": "cds watch --open so.project1/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project2": "cds watch --open epm.project2/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-purchase": "cds watch --open epm.purchase/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana-cloud",
        "[development]": { "kind": "sql" },
        "[production]": { "kind": "hana-cloud" }
      },
      "auth": {
        "kind": "xsuaa",
        "[development]": {
          "kind": "mocked",
          "users": {
            "alice":   { "password": "alice",   "roles": ["PurchaseManager"], "attr": { "Department": "Engineering" } },
            "bob":     { "password": "bob",     "roles": ["PurchaseManager"], "attr": { "Department": "Marketing" } },
            "carol":   { "password": "carol",   "roles": ["Viewer"] },
            "dave":    { "password": "dave",    "roles": ["Administrator"] },
            "viewer":  { "password": "viewer",  "roles": ["Viewer"] },
            "manager": { "password": "manager", "roles": ["PurchaseManager", "Viewer"] },
            "admin":   { "password": "admin",   "roles": ["Administrator", "PurchaseManager", "Viewer"] },
            "*": true
          }
        }
      }
    }
  },
  "private": true,
  "workspaces": [ "app/*" ],
  "sapux": [
    "app/po-management",
    "app/project1",
    "app/project2",
    "app/purchase"
  ]
}