{
  "name": "epm-complete",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9.9.1"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-po-management": "cds watch --open app.pomanagement/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project1": "cds watch --open so.project1/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project2": "cds watch --open epm.project2/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-purchase": "cds watch --open epm.purchase/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/epm.db"
        }
      }
    }
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/po-management",
    "app/po-management",
    "app/po-management",
    "app/po-management",
    "app/po-management",
    "app/project1",
    "app/project2",
    "app/project1",
    "app/project1",
    "app/project1",
    "app/project1",
    "app/po-management",
    "app/project1",
    "app/purchase"
  ]
}
